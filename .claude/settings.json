{
  "permissions": {
    "allow": [
      "Bash(dart format *)",
      "Bash(dart analyze *)",
      "Bash(dart test *)",
      "Bash(dart pub *)",
      "Bash(flutter test *)",
      "Bash(flutter pub *)",
